use zk_multisig::{verify_multi_sig, SIGNERS_MAX_DEPTH, MAX_SIGNERS};
use zk_signer::{PubKey, Signature, Hash};

fn main(
    signers: [PubKey; MAX_SIGNERS],
    threshold: u8,
    signers_root: Field,
    merkle_proof_length: [u32; MAX_SIGNERS],
    indices: [[u1; SIGNERS_MAX_DEPTH]; MAX_SIGNERS],
    siblings: [[Field; SIGNERS_MAX_DEPTH]; MAX_SIGNERS],
    signatures: [Signature; MAX_SIGNERS],
    txn_hash: pub Hash,
    on_chain_state_root: pub Field,
) {
    let _ = verify_multi_sig(
        signers, signatures, txn_hash, threshold, signers_root,
        merkle_proof_length, indices, siblings, on_chain_state_root,
    );
}

